<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/length_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="Length: 3" />

        <TextView
            android:id="@+id/apples_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="Apples: 0" />

        <TextView
            android:id="@+id/stars_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="Stars: 0" />

        <TextView
            android:id="@+id/extra_lives_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="Lifes: 0" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/best_apples_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#D6FF6B"
            android:textStyle="bold"
            android:textSize="14sp"
            android:text="Best Apples: 0" />

        <TextView
            android:id="@+id/best_time_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#D6FF6B"
            android:textStyle="bold"
            android:textSize="14sp"
            android:text="Best Time: 0s" />

        <TextView
            android:id="@+id/best_fastest_apple_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#D6FF6B"
            android:textStyle="bold"
            android:textSize="14sp"
            android:text="Fastest Apple: -" />

        <TextView
            android:id="@+id/achievements_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#D6FF6B"
            android:textStyle="bold"
            android:textSize="14sp"
            android:text="Achievements: 0/0" />
    </LinearLayout>

    <org.example.snakegame.GameView
        android:id="@+id/game_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.70"
        android:background="#000000" />

    <GridLayout
        android:id="@+id/dpad_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="3"
        android:useDefaultMargins="true"
        android:alignmentMode="alignMargins"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="10dp">

        <View
            android:background="#00000000"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_columnWeight="1" />

        <Button
            android:id="@+id/button_up"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/dpad_button"
            android:layout_margin="8dp"
            android:text="▲"
            android:textSize="28sp"
            android:textColor="#FFFFFF" />

        <View
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_columnWeight="1" />

        <Button
            android:id="@+id/button_left"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_margin="8dp"
            android:background="@drawable/dpad_button"
            android:text="◀"
            android:textSize="28sp"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/button_pause"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_margin="8dp"
            android:background="@drawable/pause_button"
            android:text="Pause"
            android:textSize="16sp"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/button_right"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_margin="8dp"
            android:background="@drawable/dpad_button"
            android:text="▶"
            android:textSize="28sp"
            android:textColor="#FFFFFF" />

        <View
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_columnWeight="1" />

        <Button
            android:id="@+id/button_down"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_margin="8dp"
            android:background="@drawable/dpad_button"
            android:text="▼"
            android:textSize="28sp"
            android:textColor="#FFFFFF" />

        <View
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_columnWeight="1" />
    </GridLayout>

    <!-- <Button
        android:id="@+id/button_restart"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/action_button"
        android:text="Restart"
        android:textColor="#FFFFFF" /> -->
</LinearLayout>
